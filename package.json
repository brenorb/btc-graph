{
  "name": "btc-graph",
  "version": "1.0.0",
  "description": "Interactive Bitcoin learning graph",
  "scripts": {
    "dev": "vite",
    "build:data": "node scripts/build-graph.mjs",
    "build:content-audit": "node scripts/build-content-source-audit.mjs --out outputs/content-source-audit/btc-graph-content-source-audit.xlsx",
    "check:links": "node scripts/check-links.mjs",
    "build": "npm run build:data && vite build",
    "preview": "vite preview",
    "test": "npm run build:data && vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brenorb/btc-graph.git"
  },
  "keywords": [
    "bitcoin",
    "learning-graph",
    "education",
    "lightning-network",
    "seo"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/brenorb/btc-graph/issues"
  },
  "homepage": "https://btc-graph.brenorb.com/",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "cytoscape": "^3.33.1",
    "cytoscape-dagre": "^2.5.0"
  }
}
